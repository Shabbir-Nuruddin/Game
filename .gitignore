# Unity-generated folders (rebuilt locally, never committed)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.user
*.userprefs

# OS files
.DS_Store
Thumbs.db

# Unity crash/asset import junk
*.pidb
*.booproj
*.svd
sysinfo.txt
*.apk
*.aab
*.unitypackage

# Large third-party asset packs + SDK — kept local, re-import as needed.
# The game loads its runtime assets from Assets/Resources (which IS committed).
/Assets/Art/
/Assets/Art.meta
/Assets/Photon/
/Assets/Photon.meta

# Node dependencies / secrets for the analytics server
node_modules/
.env

# Android/Gradle native build cache (headless compile-check scratch)
.utmp/
