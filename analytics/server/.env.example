# Copy this file to ".env" and fill in real values. Never commit your real .env.

# Postgres connection string from Neon (neon.tech).
# Looks like: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Login for the dashboard (HTTP Basic auth). Pick anything.
# If left blank, the dashboard is open (fine for local dev only).
DASH_USER=admin
DASH_PASS=change-me

# Port to listen on (Render sets this automatically; 3000 locally).
PORT=3000
